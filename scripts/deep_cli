#!/usr/bin/env bash
set -euo pipefail

DEEP_CLI_HOME="${DEEP_CLI_HOME:-/path/to/deepcli}"
DEEP_CLI_BIN="${DEEP_CLI_BIN:-$DEEP_CLI_HOME/target/debug/deep-cli}"
DEEP_CLI_CONFIG="${DEEP_CLI_CONFIG:-$DEEP_CLI_HOME/.deepcli/config.json}"

ensure_binary() {
  if [[ ! -x "$DEEP_CLI_BIN" ]]; then
    echo "deep_cli: building deep-cli binary..." >&2
    (cd "$DEEP_CLI_HOME" && cargo build --quiet)
  fi
}

load_api_key() {
  local env_name="$1"
  local credentials_file="$2"
  if [[ -n "${!env_name:-}" || ! -r "$credentials_file" ]]; then
    return
  fi

  local api_key
  api_key="$(
    /usr/bin/python3 - "$credentials_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
try:
    value = json.loads(path.read_text())
except Exception:
    raise SystemExit(0)

api_key = value.get("apiKey") or ""
if api_key:
    print(api_key)
PY
  )"
  if [[ -n "$api_key" ]]; then
    export "$env_name=$api_key"
  fi
}

load_default_credentials() {
  load_api_key "DEEPSEEK_API_KEY" "$DEEP_CLI_HOME/.deepcli/credentials/deepseek-credentials.json"
  load_api_key "KIMI_API_KEY" "$DEEP_CLI_HOME/.deepcli/credentials/kimi-credentials.json"
}

latest_session_id() {
  /usr/bin/python3 - "$PWD" <<'PY'
import json
import pathlib
import sys

root = pathlib.Path(sys.argv[1]) / ".deepcli" / "sessions"
items = []
if root.exists():
    for metadata in root.glob("*/metadata.json"):
        try:
            data = json.loads(metadata.read_text())
        except Exception:
            continue
        items.append((data.get("updated_at") or data.get("created_at") or "", data.get("id") or metadata.parent.name))

items.sort(reverse=True)
if items:
    print(items[0][1])
PY
}

list_sessions() {
  /usr/bin/python3 - "$PWD" <<'PY'
import json
import pathlib
import sys

root = pathlib.Path(sys.argv[1]) / ".deepcli" / "sessions"
items = []
if root.exists():
    for metadata in root.glob("*/metadata.json"):
        try:
            data = json.loads(metadata.read_text())
        except Exception:
            continue
        items.append(data)

items.sort(key=lambda item: item.get("updated_at") or item.get("created_at") or "", reverse=True)
if not items:
    print(f"no sessions found under {root}")
    raise SystemExit(0)

for item in items:
    model = item.get("model") or "<unset>"
    print(f"{item.get('id')}  provider={item.get('provider')}  model={model}  updated_at={item.get('updated_at')}")
PY
}

usage() {
  cat <<'EOF'
Usage:
  deep_cli                         Start the terminal UI in the current directory
  deep_cli repl                    Start the legacy line-based REPL
  deep_cli resume [session_id]     Resume a session; without id, resume the latest session in this directory
  deep_cli sessions                List sessions for the current directory
  deep_cli tui                     Start the terminal UI in the current directory
  deep_cli ask <prompt>            Run a one-shot task in the current directory
  deep_cli stream <prompt>         Run a streaming one-shot chat task
  deep_cli kimi [ask|stream|resume|tui|repl] [args...]
                                   Use --provider kimi --model kimi-for-coding
  deep_cli deepseek [ask|stream|resume|tui|repl] [args...]
                                   Use --provider deepseek --model deepseek-v4-pro
  deep_cli help                    Show this help

All other arguments are forwarded to deep-cli with:
  -C "$PWD" --config "$DEEP_CLI_CONFIG" --yes

Examples:
  deep_cli
  deep_cli repl
  deep_cli tui
  deep_cli resume
  deep_cli resume 6155c14e-85e5-4600-a081-29359cc232f2
  deep_cli kimi
  deep_cli deepseek ask '阅读项目结构并说明如何运行测试'
  deep_cli kimi stream '请只回答 OK'
  deep_cli --provider kimi --model kimi-for-coding
EOF
}

run_deep_cli() {
  ensure_binary
  load_default_credentials
  exec "$DEEP_CLI_BIN" -C "$PWD" --config "$DEEP_CLI_CONFIG" --yes "$@"
}

run_provider_command() {
  local provider="$1"
  local model="$2"
  shift 2

  case "${1:-}" in
    "" )
      run_deep_cli --provider "$provider" --model "$model" --tui
      ;;
    ask )
      shift
      run_deep_cli --provider "$provider" --model "$model" "$@"
      ;;
    stream )
      shift
      run_deep_cli --provider "$provider" --model "$model" --stream "$@"
      ;;
    tui )
      shift
      run_deep_cli --provider "$provider" --model "$model" --tui "$@"
      ;;
    repl )
      shift
      run_deep_cli --provider "$provider" --model "$model" "$@"
      ;;
    resume )
      shift
      local session_id="${1:-}"
      if [[ -z "$session_id" ]]; then
        session_id="$(latest_session_id)"
        if [[ -z "$session_id" ]]; then
          echo "deep_cli: no session found under $PWD/.deepcli/sessions" >&2
          exit 1
        fi
      else
        shift
      fi
      run_deep_cli --provider "$provider" --model "$model" --tui --resume "$session_id" "$@"
      ;;
    * )
      run_deep_cli --provider "$provider" --model "$model" "$@"
      ;;
  esac
}

case "${1:-}" in
  "" )
    run_deep_cli --tui
    ;;
  help|--help|-h )
    usage
    ;;
  resume )
    shift
    session_id="${1:-}"
    if [[ -z "$session_id" ]]; then
      session_id="$(latest_session_id)"
      if [[ -z "$session_id" ]]; then
        echo "deep_cli: no session found under $PWD/.deepcli/sessions" >&2
        exit 1
      fi
    else
      shift
    fi
    run_deep_cli --tui --resume "$session_id" "$@"
    ;;
  sessions|session )
    list_sessions
    ;;
  tui )
    shift
    run_deep_cli --tui "$@"
    ;;
  repl )
    shift
    run_deep_cli "$@"
    ;;
  ask )
    shift
    run_deep_cli "$@"
    ;;
  stream )
    shift
    run_deep_cli --stream "$@"
    ;;
  kimi )
    shift
    run_provider_command kimi kimi-for-coding "$@"
    ;;
  deepseek )
    shift
    run_provider_command deepseek deepseek-v4-pro "$@"
    ;;
  * )
    run_deep_cli "$@"
    ;;
esac
