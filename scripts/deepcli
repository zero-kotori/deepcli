run_deepcli() {
  ensure_binary
  load_default_credentials
  local args=()
  if ! has_cwd_arg "$@"; then
    args+=(-C "$PWD")
  fi
  if ! has_config_arg "$@"; then
    args+=(--config "$DEEPCLI_CONFIG")
  fi
  if ! has_yes_arg "$@"; then
    args+=(--yes)
  fi
  if ((${#args[@]})); then
    exec "$DEEPCLI_BIN" "${args[@]}" "$@"
  else
    exec "$DEEPCLI_BIN" "$@"
  fi
}

run_provider_command() {
  local provider="$1"
  local model="$2"
  shift 2

  if [[ -n "${1:-}" ]] && help_topic="$(help_topic_for_top_level_command "$1")" && is_help_flag "${2:-}"; then
    run_deepcli --provider "$provider" --model "$model" /help "$help_topic"
  fi

  case "${1:-}" in
    "" )
      run_deepcli --provider "$provider" --model "$model" --tui
      ;;
    ask )
      run_deepcli --provider "$provider" --model "$model" "$@"
      ;;
    stream )
      run_deepcli --provider "$provider" --model "$model" "$@"
      ;;
    tui )
      shift
      run_deepcli --provider "$provider" --model "$model" --tui "$@"
      ;;
    repl )
      shift
      run_deepcli --provider "$provider" --model "$model" --repl "$@"
      ;;
    resume )
      shift
      local session_id="${1:-}"
      if [[ -z "$session_id" ]]; then
        run_deepcli --provider "$provider" --model "$model" --resume-picker "$@"
      else
        shift
        run_deepcli --provider "$provider" --model "$model" --tui --resume "$session_id" "$@"
      fi
      ;;
    diagnose )
      shift
      run_deepcli --provider "$provider" --model "$model" /diagnose "$@"
      ;;
    check )
      shift
      run_deepcli --provider "$provider" --model "$model" /check "$@"
      ;;
    test )
      shift
      case "${1:-}" in
        docker|compiler )
          run_deepcli --provider "$provider" --model "$model" /env test "$@"
          ;;
        * )
          run_deepcli --provider "$provider" --model "$model" /test "$@"
          ;;
      esac
      ;;
    login|auth|apikey|key )
      local slash_command="$1"
      shift
      if [[ "${1:-}" == "" || "${1:-}" == --* ]]; then
        run_deepcli --provider "$provider" --model "$model" "/$slash_command" "$provider" "$@"
      else
        run_deepcli --provider "$provider" --model "$model" "/$slash_command" "$@"
      fi
      ;;
    logout )
      shift
      if [[ "${1:-}" == "" || "${1:-}" == --* ]]; then
        run_deepcli --provider "$provider" --model "$model" /logout "$provider" "$@"
      else
        run_deepcli --provider "$provider" --model "$model" /logout "$@"
      fi
      ;;
    use|switch )
      local slash_command="$1"
      shift
      if [[ "${1:-}" == "" || "${1:-}" == --* ]]; then
        run_deepcli --provider "$provider" --model "$model" "/$slash_command" "$provider" "$@"
      else
        run_deepcli --provider "$provider" --model "$model" "/$slash_command" "$@"
      fi
      ;;
    * )
      if is_top_level_slash_command "$1"; then
        local slash_command="$1"
        shift
        run_deepcli --provider "$provider" --model "$model" "/$slash_command" "$@"
      else
        run_deepcli --provider "$provider" --model "$model" "$@"
      fi
      ;;
  esac
}

case "${1:-}" in
  "" )
    run_deepcli --tui
    ;;
  * )
    if [[ -n "${1:-}" ]] && help_topic="$(help_topic_for_top_level_command "$1")" && is_help_flag "${2:-}"; then
      run_deepcli /help "$help_topic"
    fi
    ;;
esac

case "${1:-}" in
  "" )
    run_deepcli --tui
    ;;
  help )
    shift
    if [[ "${1:-}" == "" ]]; then
      usage
    else
      run_deepcli /help "$@"
    fi
    ;;
  --help|-h )
    usage
    ;;
  resume )
    shift
    session_id="${1:-}"
    if [[ -z "$session_id" ]]; then
      run_deepcli --resume-picker "$@"
    else
      shift
      run_deepcli --tui --resume "$session_id" "$@"
    fi
    ;;
  sessions )
    shift
    run_deepcli /session list "$@"
    ;;
  session )
    shift
    if [[ "${1:-}" == "" ]]; then
      run_deepcli /session list
    else
      run_deepcli /session "$@"
    fi
    ;;
  diagnose )
    shift
    run_deepcli /diagnose "$@"
    ;;
  support )
    shift
    run_deepcli /support "$@"
    ;;
  check )
    shift
    run_deepcli /check "$@"
    ;;
  test )
    shift
    case "${1:-}" in
      docker|compiler )
        run_deepcli /env test "$@"
        ;;
      * )
        run_deepcli /test "$@"
        ;;
    esac
    ;;
  tui )
    shift
    run_deepcli --tui "$@"
    ;;
  repl )
    shift
    run_deepcli --repl "$@"
    ;;
  ask )
    run_deepcli "$@"
    ;;
  stream )
    run_deepcli "$@"
    ;;
  kimi )
    shift
    run_provider_command kimi kimi-for-coding "$@"
    ;;
  deepseek )
    shift
    run_provider_command deepseek deepseek-v4-pro "$@"
    ;;
  version|about|quickstart|recipes|recipe|playbook|workflow|workflows|scorecard|benchmark|bench|sota|round|iterate|iteration|selftest|preflight|release-check|completion|completions|init|status|usage|health|diagnose|support|next|doctor|trace|logs|privacy|log|context|permissions|login|auth|apikey|key|logout|credentials|config|timeout|model|provider|use|switch|models|providers|goal|plan|fork|diff|review|accept|gate|verify|handoff|env|docker|compiler|setup|install|git|web|search|prompt|skill|agent|btw|approval|history|cleanup|rename|stop|quit|terminal )
    slash_command="$1"
    shift
    if is_help_flag "${1:-}"; then
      help_topic="$(help_topic_for_top_level_command "$slash_command")"
      run_deepcli /help "$help_topic"
    else
      run_deepcli "/$slash_command" "$@"
    fi
    ;;
  * )
    run_deepcli "$@"
    ;;
esac
