#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET"
  fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
DEEPCLI_HOME="${DEEPCLI_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
DEEPCLI_BIN="${DEEPCLI_BIN:-$DEEPCLI_HOME/target/debug/deepcli}"
DEEPCLI_CONFIG="${DEEPCLI_CONFIG:-$DEEPCLI_HOME/.deepcli/config.json}"

binary_needs_build() {
  if [[ ! -x "$DEEPCLI_BIN" ]]; then
    return 0
  fi

  local path
  for path in "$DEEPCLI_HOME/Cargo.toml" "$DEEPCLI_HOME/Cargo.lock" "$DEEPCLI_HOME/src"; do
    if [[ -e "$path" ]] && find "$path" -newer "$DEEPCLI_BIN" -print -quit | grep -q .; then
      return 0
    fi
  done
  return 1
}

ensure_binary() {
  if binary_needs_build; then
    echo "deepcli: building deepcli binary..." >&2
    (cd "$DEEPCLI_HOME" && cargo build --quiet)
  fi
}

load_api_key() {
  local env_name="$1"
  local credentials_file="$2"
  if [[ -n "${!env_name:-}" || ! -r "$credentials_file" ]]; then
    return
  fi

  local api_key
  api_key="$(
    /usr/bin/python3 - "$credentials_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
try:
    value = json.loads(path.read_text())
except Exception:
    raise SystemExit(0)

api_key = value.get("apiKey") or ""
if api_key:
    print(api_key)
PY
  )"
  if [[ -n "$api_key" ]]; then
    export "$env_name=$api_key"
  fi
}

load_default_credentials() {
  load_api_key "DEEPSEEK_API_KEY" "$DEEPCLI_HOME/.deepcli/credentials/deepseek-credentials.json"
  load_api_key "KIMI_API_KEY" "$DEEPCLI_HOME/.deepcli/credentials/kimi-credentials.json"
}

has_cwd_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -C|--cwd|--cwd=*|-C?* )
        return 0
        ;;
    esac
  done
  return 1
}

has_config_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --config|--config=* )
        return 0
        ;;
    esac
  done
  return 1
}

has_yes_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -y|--yes )
        return 0
        ;;
    esac
  done
  return 1
}

is_help_flag() {
  case "${1:-}" in
    --help|-h )
      return 0
      ;;
    * )
      return 1
      ;;
  esac
}

is_top_level_slash_command() {
  case "$1" in
    help|version|about|quickstart|recipes|recipe|playbook|workflow|workflows|scorecard|benchmark|bench|sota|round|iterate|iteration|selftest|preflight|release-check|completion|completions|init|status|usage|health|diagnose|support|next|doctor|trace|logs|privacy|log|context|permissions|login|auth|apikey|key|logout|credentials|config|timeout|model|provider|use|switch|models|providers|goal|plan|fork|diff|review|accept|gate|verify|handoff|test|env|check|docker|compiler|setup|install|git|web|search|prompt|skill|agent|btw|approval|session|history|cleanup|rename|stop|quit|terminal )
      return 0
      ;;
    * )
      return 1
      ;;
  esac
}

help_topic_for_top_level_command() {
  case "${1:-}" in
    sessions|history )
      printf '%s\n' session
      return 0
      ;;
    models|providers )
      printf '%s\n' model
      return 0
      ;;
    * )
      if is_top_level_slash_command "${1:-}"; then
        printf '%s\n' "$1"
        return 0
      fi
      ;;
  esac
  return 1
}

